# Mutavaatir environment variables
# Copy this file to `.env.local` and fill in your Supabase project values.
# Restart `next dev` after editing.

# Public site URL used in metadata, robots.txt and sitemap.xml
# NEXT_PUBLIC_SITE_URL=https://mutavaatir.com

# Optional — Google Search Console HTML tag verification token (public)
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=...

# Supabase — required for the /admin panel
# Find these in your Supabase project: Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
