# Mutavaatir environment variables
# Copy this file to `.env.local` and fill in your Supabase project values.
# Restart `next dev` after editing.

# Public site URL used in metadata, robots.txt and sitemap.xml
# NEXT_PUBLIC_SITE_URL=https://www.mutavaatir.pk

# Optional — Google Search Console HTML tag verification token (public)
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=...

# Supabase — server-only (do NOT use NEXT_PUBLIC_* for these)
# Find URL + anon key in Supabase: Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# NEVER commit or expose the service role key:
# SUPABASE_SERVICE_ROLE_KEY=...
